# Set all text files to LF
* text=auto eol=lf

# Explicitly declare JS/JSX/JSON/MD as text
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.mjs  text eol=lf
*.css  text eol=lf

# Binary
*.png binary
*.jpg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
